# .dockerignore - Exclude files from Docker build context
# Only Go source, go.mod/go.sum, and configs needed for build
# =============================================================================

# Environment files (provided at runtime, never baked into image)
.env
.env.*
!.env.example

# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
docs/

# Development & IDE
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# Test files
*_test.go
test/
tests/
coverage.*

# Build artifacts
bin/
dist/
build/
*.exe
*.dll
*.so
*.dylib

# Dependency directories
vendor/
node_modules/

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.log
*.tmp

# Docker files
docker-compose*.yml
Dockerfile*
deployments/

# Not needed in container
scripts/
landing/
admin-ui/
backups/
Makefile*
*.sql
*.json
configs/
.github/
