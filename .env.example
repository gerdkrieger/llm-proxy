# =============================================================================
# LLM-PROXY ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_TIMEOUT=300s
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_NAME=llm_proxy
DB_USER=proxy_user
DB_PASSWORD=your_secure_db_password_here_min_16_chars
DB_MAX_CONNECTIONS=25
DB_SSL_MODE=disable

# Connection string (alternative to individual values)
# DATABASE_URL=postgres://proxy_user:password@localhost:5433/llm_proxy?sslmode=disable

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# Connection string (alternative)
# REDIS_URL=redis://localhost:6380/0

# -----------------------------------------------------------------------------
# OAUTH & JWT CONFIGURATION
# -----------------------------------------------------------------------------
# CRITICAL: Generate a strong secret (min 32 characters)
# Generate with: openssl rand -base64 32
OAUTH_JWT_SECRET=your-super-secret-jwt-key-min-32-chars-CHANGE-THIS
OAUTH_ACCESS_TOKEN_TTL=1h
OAUTH_REFRESH_TOKEN_TTL=720h
OAUTH_ISSUER=llm-proxy

# -----------------------------------------------------------------------------
# ADMIN CONFIGURATION
# -----------------------------------------------------------------------------
# CRITICAL: Generate secure admin API keys
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=admin_your-secure-api-key-here-CHANGE-THIS

# Multiple admin keys (comma-separated)
# ADMIN_API_KEYS=admin_key1,admin_key2,admin_key3

# -----------------------------------------------------------------------------
# CLAUDE API CONFIGURATION
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-your-claude-api-key-here

# Multiple Claude API keys for load balancing (comma-separated)
# CLAUDE_API_KEYS=sk-ant-api03-key1,sk-ant-api03-key2,sk-ant-api03-key3

# -----------------------------------------------------------------------------
# CACHE CONFIGURATION
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_PREFIX=llm-proxy:

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMITING_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=1000
RATE_LIMIT_DEFAULT_RPD=50000

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# -----------------------------------------------------------------------------
# METRICS & MONITORING
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Enable CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3000

# Enable TLS (for production)
TLS_ENABLED=false
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES (Optional - Post-MVP)
# -----------------------------------------------------------------------------
# Google Perspective API (for content filtering)
# PERSPECTIVE_API_KEY=your-perspective-api-key

# SendGrid (for email notifications)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Slack (for notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# -----------------------------------------------------------------------------
# DEVELOPMENT / TESTING
# -----------------------------------------------------------------------------
# Set to 'development' for detailed logging, 'production' for optimized performance
ENVIRONMENT=development

# Enable debug mode (verbose logging)
DEBUG=false

# Enable SQL query logging
SQL_DEBUG=false

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
