# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.production and update with your production values
# NEVER commit .env.production to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
ENVIRONMENT=production
SERVER_PORT=8080
METRICS_PORT=9091
ADMIN_UI_PORT=3005

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=llm_proxy
DB_USER=proxy_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# OAUTH / JWT
# -----------------------------------------------------------------------------
# CRITICAL SECURITY: JWT Secret MUST be at least 64 characters (512 bits)
# The application will FAIL TO START if the secret is too short!
#
# Generate a secure secret with:
#   openssl rand -base64 64 | tr -d '\n'
#
# This generates a 90-character base64-encoded secret (>64 char minimum)
OAUTH_JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_MIN_64_CHARS_USE_OPENSSL_RAND_BASE64_64

# Token expiration times
OAUTH_ACCESS_TOKEN_EXPIRY=3600      # 1 hour in seconds
OAUTH_REFRESH_TOKEN_EXPIRY=604800   # 7 days in seconds

# -----------------------------------------------------------------------------
# ADMIN API
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong API key for production!
# Example: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_GENERATE_STRONG_API_KEY

# -----------------------------------------------------------------------------
# CLAUDE API
# -----------------------------------------------------------------------------
# Add your Claude API key(s) here
# Multiple keys can be configured in configs/config.yaml
CLAUDE_API_KEY=sk-ant-api03-your-key-here

# -----------------------------------------------------------------------------
# CACHING
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600              # 1 hour in seconds
CACHE_MAX_SIZE=1000                 # Maximum number of cached items

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info                       # trace, debug, info, warn, error, fatal
LOG_FORMAT=json                      # json or console
LOG_OUTPUT=stdout                    # stdout, stderr, or file path

# -----------------------------------------------------------------------------
# MONITORING (Prometheus)
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PATH=/metrics

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# ADMIN UI
# -----------------------------------------------------------------------------
# URL where the backend API is accessible
VITE_API_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3005,https://your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
CORS_MAX_AGE=3600

# TLS/SSL (if terminating SSL at the application level)
TLS_ENABLED=false
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem

# -----------------------------------------------------------------------------
# PERFORMANCE
# -----------------------------------------------------------------------------
# Request timeout in seconds
REQUEST_TIMEOUT=30

# Max request body size in MB
MAX_REQUEST_SIZE=10

# Worker pool size
WORKER_POOL_SIZE=10

# -----------------------------------------------------------------------------
# CLAUDE PROVIDER SETTINGS
# -----------------------------------------------------------------------------
# Retry configuration
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_DELAY=1000             # milliseconds
CLAUDE_TIMEOUT=60000                # milliseconds

# Cost per million tokens (adjust based on Claude pricing)
CLAUDE_COST_PER_MILLION_INPUT_TOKENS=3.00
CLAUDE_COST_PER_MILLION_OUTPUT_TOKENS=15.00

# -----------------------------------------------------------------------------
# HEALTH CHECKS
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30            # seconds
HEALTH_CHECK_TIMEOUT=10             # seconds

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 
# 1. Generate strong secrets:
#    - OAUTH_JWT_SECRET: openssl rand -base64 32
#    - ADMIN_API_KEY: openssl rand -hex 32
#    - DB_PASSWORD: openssl rand -base64 24
#    - GRAFANA_ADMIN_PASSWORD: openssl rand -base64 16
#
# 2. Update CORS settings to match your domain
#
# 3. Configure TLS/SSL certificates if not using a reverse proxy
#
# 4. Adjust resource limits in docker-compose.prod.yml based on your load
#
# 5. Set up log aggregation (ELK, Loki, etc.) for production logging
#
# 6. Configure backup strategy for PostgreSQL volumes
#
# 7. Set up monitoring alerts in Grafana
#
# =============================================================================
