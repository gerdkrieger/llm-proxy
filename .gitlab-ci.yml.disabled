# =============================================================================
# LLM-PROXY GITLAB CI/CD PIPELINE
# =============================================================================
# Stages: lint, test, security, docker, deploy
# =============================================================================

stages:
  - lint
  - test
  - security
  - docker
  - deploy

# =============================================================================
# VARIABLES
# =============================================================================

variables:
  # Go configuration
  GO_VERSION: "1.25"
  CGO_ENABLED: "0"
  GOOS: "linux"
  GOARCH: "amd64"
  
  # Docker configuration
  DOCKER_DRIVER: overlay2
  DOCKER_TLS_CERTDIR: "/certs"
  
  # Docker image names (using GitLab Container Registry)
  BACKEND_IMAGE: "${CI_REGISTRY_IMAGE}/backend"
  ADMIN_UI_IMAGE: "${CI_REGISTRY_IMAGE}/admin-ui"
  
  # Cache configuration
  GOPATH: "${CI_PROJECT_DIR}/.go"
  GOCACHE: "${CI_PROJECT_DIR}/.cache/go-build"

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

.go-cache:
  cache:
    key: "${CI_COMMIT_REF_SLUG}-go"
    paths:
      - .go/pkg/mod/
      - .cache/go-build/

.node-cache:
  cache:
    key: "${CI_COMMIT_REF_SLUG}-node"
    paths:
      - admin-ui/node_modules/

# =============================================================================
# STAGE 1: LINT
# =============================================================================

lint:backend:
  stage: lint
  image: golang:${GO_VERSION}-alpine
  extends: .go-cache
  before_script:
    - apk add --no-cache git make
    - go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest
  script:
    - echo "Running Go linter..."
    - golangci-lint run --timeout=5m ./...
  only:
    - merge_requests
    - main
    - develop

lint:admin-ui:
  stage: lint
  image: node:22-alpine
  extends: .node-cache
  before_script:
    - cd admin-ui
    - npm ci
  script:
    - echo "Running JavaScript/Svelte linter..."
    - npm run lint || true  # Continue even if no lint script
  only:
    - merge_requests
    - main
    - develop

format:check:
  stage: lint
  image: golang:${GO_VERSION}-alpine
  script:
    - echo "Checking Go code formatting..."
    - gofmt -l .
    - test -z "$(gofmt -l .)" || (echo "Code is not formatted. Run 'make fmt'" && exit 1)
  only:
    - merge_requests
    - main

# =============================================================================
# STAGE 2: TEST
# =============================================================================

test:unit:
  stage: test
  image: golang:${GO_VERSION}-alpine
  extends: .go-cache
  services:
    - postgres:14-alpine
    - redis:7-alpine
  variables:
    POSTGRES_DB: llm_proxy_test
    POSTGRES_USER: test_user
    POSTGRES_PASSWORD: test_password
    DB_HOST: postgres
    DB_PORT: "5432"
    DB_NAME: llm_proxy_test
    DB_USER: test_user
    DB_PASSWORD: test_password
    REDIS_HOST: redis
    REDIS_PORT: "6379"
  before_script:
    - apk add --no-cache git gcc musl-dev postgresql-client
    - go mod download
  script:
    - echo "Running unit tests..."
    - go test -v -race -coverprofile=coverage.txt -covermode=atomic ./...
    - go tool cover -func=coverage.txt
  coverage: '/total:.*?(\d+\.\d+)%/'
  artifacts:
    reports:
      coverage_report:
        coverage_format: cobertura
        path: coverage.txt
    paths:
      - coverage.txt
      - coverage.html
    expire_in: 1 week
  only:
    - merge_requests
    - main
    - develop

test:integration:
  stage: test
  image: golang:${GO_VERSION}-alpine
  extends: .go-cache
  services:
    - postgres:14-alpine
    - redis:7-alpine
  variables:
    POSTGRES_DB: llm_proxy_test
    POSTGRES_USER: test_user
    POSTGRES_PASSWORD: test_password
    DB_HOST: postgres
    DB_PORT: "5432"
    DB_NAME: llm_proxy_test
    DB_USER: test_user
    DB_PASSWORD: test_password
    REDIS_HOST: redis
    REDIS_PORT: "6379"
  before_script:
    - apk add --no-cache git gcc musl-dev postgresql-client
    - go mod download
  script:
    - echo "Running integration tests..."
    - go test -v -tags=integration ./tests/integration/... || true
  allow_failure: true
  only:
    - merge_requests
    - main
    - develop

test:admin-ui:
  stage: test
  image: node:22-alpine
  extends: .node-cache
  before_script:
    - cd admin-ui
    - npm ci
  script:
    - echo "Running Admin UI tests..."
    - npm test || true  # Continue even if no tests
  allow_failure: true
  only:
    - merge_requests
    - main
    - develop

# =============================================================================
# STAGE 3: SECURITY
# =============================================================================

security:go-dependencies:
  stage: security
  image: golang:${GO_VERSION}-alpine
  extends: .go-cache
  before_script:
    - apk add --no-cache git
    - go install golang.org/x/vuln/cmd/govulncheck@latest
  script:
    - echo "Checking for known vulnerabilities in Go dependencies..."
    - govulncheck ./...
  allow_failure: true
  only:
    - merge_requests
    - main
    - develop

security:npm-audit:
  stage: security
  image: node:22-alpine
  extends: .node-cache
  before_script:
    - cd admin-ui
    - npm ci
  script:
    - echo "Running npm security audit..."
    - npm audit --audit-level=moderate || true
  allow_failure: true
  only:
    - merge_requests
    - main
    - develop

security:secrets-scan:
  stage: security
  image: alpine:latest
  before_script:
    - apk add --no-cache git grep
  script:
    - echo "Scanning for potential secrets..."
    - |
      # Check for common secret patterns
      if grep -rE "password.*=.*['\"].*['\"]" --exclude-dir=.git --exclude="*.md" .; then
        echo "⚠️  Warning: Found potential hardcoded passwords"
      fi
    - |
      if grep -rE "api[_-]?key.*=.*['\"].*['\"]" --exclude-dir=.git --exclude="*.md" --exclude=".env.production.example" .; then
        echo "⚠️  Warning: Found potential hardcoded API keys"
      fi
    - echo "Secret scan complete"
  allow_failure: true
  only:
    - merge_requests
    - main

# =============================================================================
# DOCKER BUILD & PUSH
# =============================================================================

.docker-login:
  before_script:
    - echo "Logging into GitLab Container Registry..."
    - |
      if [ -n "${REGISTRY_TOKEN:-}" ]; then
        echo "Using Deploy Token (REGISTRY_USER) for registry access"
        echo "${REGISTRY_TOKEN}" | docker login -u "${REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      elif [ -n "${CI_DEPLOY_PASSWORD:-}" ]; then
        echo "Using Deploy Token (CI_DEPLOY_USER) for registry access"
        echo "${CI_DEPLOY_PASSWORD}" | docker login -u "${CI_DEPLOY_USER}" --password-stdin "${CI_REGISTRY}"
      else
        echo "Using CI_JOB_TOKEN for registry access (fallback)"
        echo "${CI_REGISTRY_PASSWORD}" | docker login -u "${CI_REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      fi

docker:backend:
  stage: docker
  image: docker:27.1.1
  services:
    - docker:dind  # Use GitLab Shared Runner with DinD
  extends: .docker-login
  before_script:
    - set -euo pipefail
    - echo "Logging into GitLab Container Registry..."
    - |
      if [ -n "${REGISTRY_TOKEN:-}" ]; then
        echo "Using Deploy Token (REGISTRY_USER) for registry access"
        echo "${REGISTRY_TOKEN}" | docker login -u "${REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      elif [ -n "${CI_DEPLOY_PASSWORD:-}" ]; then
        echo "Using Deploy Token (CI_DEPLOY_USER) for registry access"
        echo "${CI_DEPLOY_PASSWORD}" | docker login -u "${CI_DEPLOY_USER}" --password-stdin "${CI_REGISTRY}"
      else
        echo "Using CI_JOB_TOKEN for registry access (fallback)"
        echo "${CI_REGISTRY_PASSWORD}" | docker login -u "${CI_REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      fi
  script:
    - echo "Building backend Docker image..."
    - |
      docker build \
        -f deployments/docker/Dockerfile \
        -t "${BACKEND_IMAGE}:${CI_COMMIT_SHORT_SHA}" \
        -t "${BACKEND_IMAGE}:${CI_COMMIT_REF_SLUG}" \
        --build-arg VERSION="${CI_COMMIT_TAG:-${CI_COMMIT_SHORT_SHA}}" \
        --build-arg BUILD_TIME="$(date -u '+%Y-%m-%d_%H:%M:%S')" \
        --build-arg GIT_COMMIT="${CI_COMMIT_SHORT_SHA}" \
        .
    - docker push "${BACKEND_IMAGE}:${CI_COMMIT_SHORT_SHA}" || true
    - docker push "${BACKEND_IMAGE}:${CI_COMMIT_REF_SLUG}" || true
    - |
      if [ "${CI_COMMIT_REF_NAME}" = "master" ]; then
        docker tag "${BACKEND_IMAGE}:${CI_COMMIT_SHORT_SHA}" "${BACKEND_IMAGE}:latest"
        docker push "${BACKEND_IMAGE}:latest" || true
      fi
    - |
      if [ -n "${CI_COMMIT_TAG:-}" ]; then
        docker tag "${BACKEND_IMAGE}:${CI_COMMIT_SHORT_SHA}" "${BACKEND_IMAGE}:${CI_COMMIT_TAG}"
        docker push "${BACKEND_IMAGE}:${CI_COMMIT_TAG}" || true
      fi
  allow_failure: true
  when: manual  # MANUAL - Registry push scheitert, Images müssen lokal gebaut werden
  # REMOVED llm-proxy-runner tag - now uses GitLab Shared Runner
  # This prevents builds from running on the 1-CPU/2GB production server
  only:
    - master
    - develop
    - tags

docker:admin-ui:
  needs:
    - docker:backend
  stage: docker
  image: docker:27.1.1
  services:
    - docker:dind  # Use GitLab Shared Runner with DinD
  extends: .docker-login
  before_script:
    - set -euo pipefail
    - echo "Logging into GitLab Container Registry..."
    - |
      if [ -n "${REGISTRY_TOKEN:-}" ]; then
        echo "Using Deploy Token (REGISTRY_USER) for registry access"
        echo "${REGISTRY_TOKEN}" | docker login -u "${REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      elif [ -n "${CI_DEPLOY_PASSWORD:-}" ]; then
        echo "Using Deploy Token (CI_DEPLOY_USER) for registry access"
        echo "${CI_DEPLOY_PASSWORD}" | docker login -u "${CI_DEPLOY_USER}" --password-stdin "${CI_REGISTRY}"
      else
        echo "Using CI_JOB_TOKEN for registry access (fallback)"
        echo "${CI_REGISTRY_PASSWORD}" | docker login -u "${CI_REGISTRY_USER}" --password-stdin "${CI_REGISTRY}"
      fi
  script:
    - echo "Building Admin UI Docker image..."
    - |
      docker build \
        -f admin-ui/Dockerfile \
        -t "${ADMIN_UI_IMAGE}:${CI_COMMIT_SHORT_SHA}" \
        -t "${ADMIN_UI_IMAGE}:${CI_COMMIT_REF_SLUG}" \
        admin-ui/
    - docker push "${ADMIN_UI_IMAGE}:${CI_COMMIT_SHORT_SHA}" || true
    - docker push "${ADMIN_UI_IMAGE}:${CI_COMMIT_REF_SLUG}" || true
    - |
      if [ "${CI_COMMIT_REF_NAME}" = "master" ]; then
        docker tag "${ADMIN_UI_IMAGE}:${CI_COMMIT_SHORT_SHA}" "${ADMIN_UI_IMAGE}:latest"
        docker push "${ADMIN_UI_IMAGE}:latest" || true
      fi
    - |
      if [ -n "${CI_COMMIT_TAG:-}" ]; then
        docker tag "${ADMIN_UI_IMAGE}:${CI_COMMIT_SHORT_SHA}" "${ADMIN_UI_IMAGE}:${CI_COMMIT_TAG}"
        docker push "${ADMIN_UI_IMAGE}:${CI_COMMIT_TAG}" || true
      fi
  allow_failure: true
  when: manual  # MANUAL - Registry push scheitert, Images müssen lokal gebaut werden
  # REMOVED llm-proxy-runner tag - now uses GitLab Shared Runner
  # This prevents builds from running on the 1-CPU/2GB production server
  only:
    - master
    - develop
    - tags

# =============================================================================
# DEPLOY
# =============================================================================

.deploy-template:
  stage: deploy
  image: alpine:latest
  before_script:
    - apk add --no-cache openssh-client curl
    - eval $(ssh-agent -s)
    - echo "${SSH_PRIVATE_KEY}" | tr -d '\r' | ssh-add -
    - mkdir -p ~/.ssh
    - chmod 700 ~/.ssh
    - ssh-keyscan -H "${DEPLOY_HOST}" >> ~/.ssh/known_hosts
  script:
    - echo "Deploying to ${ENVIRONMENT} environment..."
    - |
      ssh ${DEPLOY_USER}@${DEPLOY_HOST} << 'EOF'
        set -e
        cd ${DEPLOY_PATH}
        
        # Pull latest images
        # Note: Use REGISTRY_USER/REGISTRY_TOKEN if available, fallback to CI variables
        docker login -u "${REGISTRY_USER:-${CI_REGISTRY_USER}}" -p "${REGISTRY_TOKEN:-${CI_REGISTRY_PASSWORD}}" "${CI_REGISTRY}"
        docker compose -f docker-compose.prod.yml pull
        
        # Restart services
        docker compose -f docker-compose.prod.yml up -d --no-build
        
        # Wait for health check
        sleep 10
        
        # Verify deployment
        curl -f http://localhost:8080/health || exit 1
        
        echo "Deployment complete!"
      EOF
  environment:
    name: ${ENVIRONMENT}
    url: ${DEPLOY_URL}

deploy:development:
  extends: .deploy-template
  variables:
    ENVIRONMENT: "development"
    DEPLOY_HOST: "${DEV_HOST}"
    DEPLOY_USER: "${DEV_USER}"
    DEPLOY_PATH: "${DEV_PATH}"
    DEPLOY_URL: "${DEV_URL}"
  only:
    - develop
  when: manual

# =============================================================================
# PRODUCTION DEPLOYMENT (runs on llm-proxy-runner on production server)
# =============================================================================

deploy:production:
  stage: deploy
  image: docker:27.1.1
  # services:
  #   - docker:dind  # Not needed - using host Docker via socket mount
  needs:
    - docker:backend
    - docker:admin-ui
  before_script:
    - set -euo pipefail
    - apk add --no-cache curl docker-compose
    - echo "Deploying to production..."
    - docker info  # Verify connection to host Docker
  script:
    # Create .env from GitLab CI/CD File Variable
    - echo "Creating .env from GitLab CI/CD variable..."
    - cp "$ENV_FILE" .env
    - chmod 600 .env
    - echo "✅ .env file created ($(wc -l < .env) lines)"
    
    # Ensure deployments directory exists and copy .env there
    - echo "📁 Checking deployments directory..."
    - ls -la
    - mkdir -p deployments
    - cp .env deployments/.env
    - echo "✅ .env copied to deployments/ directory"
    - ls -la deployments/.env
    
    # Aggressive cleanup of existing containers (prevent name conflicts)
    - echo "🧹 Force-removing any existing LLM-Proxy containers..."
    - docker stop llm-proxy-admin-ui llm-proxy-backend llm-proxy-postgres llm-proxy-redis 2>/dev/null || true
    - docker rm -f llm-proxy-admin-ui llm-proxy-backend llm-proxy-postgres llm-proxy-redis 2>/dev/null || true
    - docker ps -a | grep llm-proxy | awk '{print $1}' | xargs -r docker rm -f || true
    
    # Stop existing containers via compose (preserve volumes)
    - echo "🛑 Stopping services via docker compose..."
    - docker compose -f deployments/docker-compose.openwebui.yml down --remove-orphans || true
    
    # Remove network if it's stuck
    - docker network rm llm-proxy-network 2>/dev/null || true
    
    # Wait for cleanup to complete
    - sleep 3
    
    # NOTE: Registry push fails due to permissions, so we use manually transferred local images
    # The working images are already on the server (llm-proxy-backend:latest, llm-proxy-admin-ui:latest)
    # DO NOT pull from registry as those images may be outdated or broken
    
    - echo "🚀 Starting services with local images..."
    - docker compose -f deployments/docker-compose.openwebui.yml up -d --no-build
    
    # Wait for health checks (backend needs time on 1-CPU server)
    - sleep 60
    
    # Verify deployment
    - docker compose -f deployments/docker-compose.openwebui.yml ps
    - echo "Checking backend health (may take up to 90s on slow servers)..."
    - for i in $(seq 1 18); do curl -f http://localhost:8080/health && break || sleep 5; done
    
    - echo "Deployment complete!"
    - docker compose -f deployments/docker-compose.openwebui.yml ps
    - echo "✅ LLM-Proxy Backend running on https://llmproxy.aitrail.ch"
    - echo "✅ Admin UI accessible at https://llmproxy.aitrail.ch"
    - echo "ℹ️  Open WebUI configured at https://chat.aitrail.ch"
  environment:
    name: production
    url: https://llmproxy.aitrail.ch
  only:
    - master
  when: manual  # MANUAL - Use working local images, not broken registry images
  tags:
    - llm-proxy-runner  # Runs on production server (8GB RAM, all services)

# =============================================================================
# UTILITY JOBS
# =============================================================================

# Job to create a new release
release:
  stage: deploy
  image: registry.gitlab.com/gitlab-org/release-cli:latest
  script:
    - echo "Creating release for ${CI_COMMIT_TAG}"
  release:
    tag_name: '${CI_COMMIT_TAG}'
    description: 'Release ${CI_COMMIT_TAG}'
  only:
    - tags

# Job to cleanup old Docker images
cleanup:old-images:
  stage: deploy
  image: alpine:latest
  script:
    - echo "Cleanup job - remove old Docker images from registry"
    - echo "This should be implemented using GitLab API"
  only:
    - schedules
  when: manual
