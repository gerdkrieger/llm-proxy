# =============================================================================
# ADMIN-UI DEVELOPMENT ENVIRONMENT
# =============================================================================
# This file is used automatically when running: npm run dev
# Vite selects this based on NODE_ENV=development
# =============================================================================

# API Base URL for Development
# NOTE: This is actually IGNORED in the code because we use window.location.origin
# But kept here for documentation and potential future use
VITE_API_BASE_URL=http://localhost:8080

# Development mode
NODE_ENV=development
