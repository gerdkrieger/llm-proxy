# LLM-Proxy Admin UI Environment Configuration

# API Base URL
# - Production: Leave empty for relative URLs via reverse proxy
# - Development: Set to http://localhost:8080 for local backend
VITE_API_BASE_URL=

# Example for local development:
# VITE_API_BASE_URL=http://localhost:8080

# NOTE: This value is embedded into the JavaScript bundle at build time.
# If you change this file, you MUST rebuild the Docker image for changes to take effect.
