# LLM-Proxy Admin UI Environment Configuration

# API Base URL - MUST be set explicitly for production
# CRITICAL: Vite embeds this value into JavaScript bundle at BUILD TIME
# If you change this file, you MUST rebuild the Docker image!

# Production (recommended):
VITE_API_BASE_URL=https://llmproxy.aitrail.ch

# Development (local backend):
# VITE_API_BASE_URL=http://localhost:8080

# NOTE: Do NOT use empty value - it causes relative URLs which may not work correctly
# Always use explicit full URL (including https:// and domain)
