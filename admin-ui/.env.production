# =============================================================================
# ADMIN-UI PRODUCTION ENVIRONMENT
# =============================================================================
# This file is used automatically when running: npm run build
# Vite selects this based on NODE_ENV=production
# =============================================================================

# API Base URL for Production
# NOTE: This is actually IGNORED in the code because we use window.location.origin
# The frontend automatically detects the current domain and uses that
# This means the same build works for ANY domain (localhost, staging, production)
#
# Example:
# - On https://scrubgate.tech → API calls go to https://scrubgate.tech
# - On http://localhost:3005 → API calls go to http://localhost:3005
#
# This is the CORRECT way to handle multi-environment deployments!

# Production mode
NODE_ENV=production
